# Google Sheets credentials for Next.js server routes.
# These values must stay server-only. Do not prefix them with NEXT_PUBLIC_.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="paste-private-key-with-escaped-newlines"

# Alternative to GOOGLE_SERVICE_ACCOUNT_EMAIL and GOOGLE_PRIVATE_KEY:
# GOOGLE_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"paste-private-key-with-escaped-newlines"}

# Use one spreadsheet for both tabs, or set separate spreadsheet IDs.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_ASSIGNMENTS_SPREADSHEET_ID=
GOOGLE_ANNOTATIONS_SPREADSHEET_ID=
GOOGLE_ASSIGNMENTS_SHEET_NAME=Sheet1
GOOGLE_ANNOTATIONS_SHEET_NAME=Sheet1

# Synology File Station credentials for server-side image listing/proxying.
# For local LAN use, copy .env.synology-local.example to .env.local instead.
# Vercel can only reach the NAS if it is exposed through a reachable HTTPS hostname.
SYNOLOGY_BASE_URL=https://your-nas.example.com
SYNOLOGY_PORT=5001
SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=
SYNOLOGY_VERIFY_SSL=true
SYNOLOGY_DEFAULT_FOLDER=/volume1/camera-folder
SYNOLOGY_ALLOWED_FOLDER_PREFIX=/volume1
