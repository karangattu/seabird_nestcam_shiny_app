# Copy this file to .env.local on the computer that is on the same LAN/VPN as the NAS.
SYNOLOGY_BASE_URL=http://192.168.12.166:5000
SYNOLOGY_PORT=

SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=

# Replace with the File Station path that contains the camera images.
SYNOLOGY_DEFAULT_FOLDER=/volume1/camera-folder
SYNOLOGY_ALLOWED_FOLDER_PREFIX=/volume1
